@page "/transactions"
@rendermode InteractiveServer
@inject ITransactionService TransactionService
@inject IAssetService AssetService
@inject IPortfolioService PortfolioService
@inject ToastService Toasts
@inject ILogger<Transactions> Logger

<PageTitle>Transactions</PageTitle>

<div class="page-header">
    <i class="bi bi-arrow-left-right"></i>
    <h1>Transactions</h1>
</div>

<ConfirmDialog @ref="confirmDialog" Title="Supprimer la transaction" />

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(isSuccess ? "alert-success" : "alert-danger")">@statusMessage</div>
}

@if (initialLoadError)
{
    <div class="alert alert-danger d-flex justify-content-between align-items-center">
        <span>Echec du chargement des donnees.</span>
        <button class="btn btn-sm btn-outline-light" @onclick="LoadAllAsync">Reessayer</button>
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card kpi-card kpi-accent p-3">
            <div class="kpi-label"><i class="bi bi-wallet2"></i>Budget initial</div>
            <div class="kpi-value">@budget.InitialBudget.ToString("C")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card kpi-card p-3">
            <div class="kpi-label"><i class="bi bi-cash-coin"></i>Liquidite disponible</div>
            <div class="kpi-value">@budget.AvailableCash.ToString("C")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card kpi-card p-3">
            <div class="kpi-label"><i class="bi bi-graph-up"></i>Valeur totale</div>
            <div class="kpi-value">@snapshot.TotalValue.ToString("C")</div>
        </div>
    </div>
</div>

<div class="card p-3 mb-3">
    <div class="section-label"><i class="bi bi-plus-circle"></i>Nouvelle transaction</div>
    <EditForm Model="transactionForm" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Actif</label>
                <InputSelect class="form-select" @bind-Value="transactionForm.AssetId">
                    <option value="0">Choisir...</option>
                    @foreach (var asset in assets)
                    {
                        <option value="@asset.Id">@asset.Symbol - @asset.Name</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-2">
                <label class="form-label">Type</label>
                <InputSelect class="form-select" @bind-Value="transactionForm.Type">
                    <option value="Buy">Buy</option>
                    <option value="Sell">Sell</option>
                </InputSelect>
            </div>
            <div class="col-md-2">
                <label class="form-label">Quantite</label>
                <InputNumber class="form-control" @bind-Value="transactionForm.Quantity" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Prix unitaire</label>
                <InputNumber class="form-control" @bind-Value="transactionForm.UnitPrice" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-1" type="submit">
                    <i class="bi bi-save"></i>Enregistrer
                </button>
            </div>
        </div>
    </EditForm>
</div>

<div class="card p-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
        <div>
            <h5 class="mb-0 d-flex align-items-center gap-2"><i class="bi bi-clock-history text-muted"></i>Historique des operations</h5>
            <span class="text-muted small mt-1 d-block">@totalCount operation(s) &middot; @($"Page {page} / {totalPages}")</span>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <select class="form-select form-select-sm" style="width: auto;" @bind="sortBy" @bind:after="() => LoadPageAsync(1)">
                <option value="date">Date</option>
                <option value="symbol">Symbole</option>
                <option value="amount">Montant</option>
                <option value="type">Type</option>
            </select>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="sortDesc" @bind:after="() => LoadPageAsync(1)" id="txSortDesc" />
                <label class="form-check-label small" for="txSortDesc">Decroissant</label>
            </div>
            @if (!string.IsNullOrEmpty(csvDownloadHref))
            {
                <a class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" href="@csvDownloadHref" download="transactions.csv">
                    <i class="bi bi-download"></i>CSV
                </a>
            }
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" disabled="@(page <= 1)" @onclick="() => LoadPageAsync(page - 1)" title="Page precedente">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button class="btn btn-outline-secondary" disabled="@(page >= totalPages)" @onclick="() => LoadPageAsync(page + 1)" title="Page suivante">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
    @if (isLoading)
    {
        <LoadingSpinner Message="Chargement des transactions..." />
    }
    else if (pageItems.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-receipt empty-icon"></i>
            <div class="empty-title">Aucune transaction enregistree</div>
            <p class="empty-message">Achetez ou vendez un actif pour faire apparaitre l'historique ici.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Actif</th>
                        <th>Type</th>
                        <th class="text-end">Quantite</th>
                        <th class="text-end">Prix</th>
                        <th class="text-end">Montant</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in pageItems)
                    {
                        <tr>
                            <td class="text-muted small tabular-nums">@t.Date.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td><strong>@t.Asset?.Symbol</strong></td>
                            <td>
                                <span class="tag-signal @(t.Type == TransactionType.Buy ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning")">
                                    <i class="bi @(t.Type == TransactionType.Buy ? "bi-arrow-down-left" : "bi-arrow-up-right")"></i>
                                    @t.Type
                                </span>
                            </td>
                            <td class="text-end tabular-nums">@t.Quantity</td>
                            <td class="text-end tabular-nums">@t.UnitPrice.ToString("C")</td>
                            <td class="text-end tabular-nums fw-semibold">@t.TotalAmount.ToString("C")</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(t)" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private const int PageSize = 10;

    private List<Asset> assets = [];
    private List<Transaction> allTransactionsExport = [];
    private List<Transaction> pageItems = [];
    private int totalCount;
    private int page = 1;
    private int totalPages => Math.Max(1, (int)Math.Ceiling(totalCount / (double)PageSize));
    private string sortBy = "date";
    private bool sortDesc = true;
    private PortfolioBudget budget = new();
    private PortfolioSnapshot snapshot = new();
    private bool isSuccess;
    private string? statusMessage;
    private string? csvDownloadHref;
    private ConfirmDialog? confirmDialog;
    private bool isLoading;
    private bool initialLoadError;

    private Transaction transactionForm = new()
    {
        Type = TransactionType.Buy,
        Quantity = 1,
        UnitPrice = 100,
        Date = DateTime.UtcNow
    };

    protected override async Task OnInitializedAsync() => await LoadAllAsync();

    private async Task LoadAllAsync()
    {
        isLoading = true;
        initialLoadError = false;
        try
        {
            assets = await AssetService.GetAllAsync();
            budget = await PortfolioService.GetBudgetAsync();
            snapshot = await PortfolioService.GetSnapshotAsync();
            allTransactionsExport = await TransactionService.GetAllAsync();
            await LoadPageInternalAsync(page);
            BuildCsvHref();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Echec du chargement des transactions");
            initialLoadError = true;
            Toasts.ShowError("Erreur", "Impossible de charger les transactions.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPageAsync(int newPage)
    {
        isLoading = true;
        try
        {
            await LoadPageInternalAsync(newPage);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Echec du chargement de la page {Page}", newPage);
            Toasts.ShowError("Erreur", "Impossible de charger la page.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPageInternalAsync(int newPage)
    {
        page = Math.Max(1, newPage);
        var result = await TransactionService.GetPagedAsync(page, PageSize, sortBy, sortDesc, null);
        pageItems = result.Items;
        totalCount = result.TotalCount;
        if (page > totalPages && totalPages > 0)
        {
            page = totalPages;
            result = await TransactionService.GetPagedAsync(page, PageSize, sortBy, sortDesc, null);
            pageItems = result.Items;
        }
    }

    private void BuildCsvHref()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Date;Symbole;Type;Quantite;PrixUnitaire;MontantTotal");
        foreach (var t in allTransactionsExport.OrderByDescending(x => x.Date))
        {
            sb.Append(t.Date.ToUniversalTime().ToString("yyyy-MM-dd HH:mm"));
            sb.Append(';');
            sb.Append(t.Asset?.Symbol ?? string.Empty);
            sb.Append(';');
            sb.Append(t.Type);
            sb.Append(';');
            sb.Append(t.Quantity.ToString(System.Globalization.CultureInfo.InvariantCulture));
            sb.Append(';');
            sb.Append(t.UnitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture));
            sb.Append(';');
            sb.AppendLine(t.TotalAmount.ToString(System.Globalization.CultureInfo.InvariantCulture));
        }

        csvDownloadHref = "data:text/csv;charset=utf-8," + Uri.EscapeDataString(sb.ToString());
    }

    private async Task SaveAsync()
    {
        if (transactionForm.AssetId <= 0)
        {
            isSuccess = false;
            statusMessage = "Veuillez choisir un actif.";
            Toasts.ShowWarning("Validation", "Veuillez choisir un actif.");
            return;
        }

        try
        {
            var result = await TransactionService.CreateAsync(transactionForm);
            isSuccess = result.Success;
            statusMessage = result.Message;

            if (result.Success)
            {
                Toasts.ShowSuccess("Transaction enregistree", result.Message);
                transactionForm = new Transaction
                {
                    AssetId = transactionForm.AssetId,
                    Type = TransactionType.Buy,
                    Quantity = 1,
                    UnitPrice = 100,
                    Date = DateTime.UtcNow
                };
            }
            else
            {
                Toasts.ShowWarning("Transaction refusee", result.Message);
            }

            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Echec de l'enregistrement de la transaction (AssetId={AssetId})", transactionForm.AssetId);
            Toasts.ShowError("Erreur", "L'enregistrement a echoue.");
        }
    }

    private async Task DeleteAsync(Transaction t)
    {
        if (confirmDialog is null)
        {
            return;
        }

        var label = $"{t.Type} {t.Quantity} {t.Asset?.Symbol} @ {t.UnitPrice:C}";
        var confirmed = await confirmDialog.ShowAsync(
            $"Voulez-vous vraiment supprimer la transaction : {label} ? Cette action est irreversible.");

        if (!confirmed)
        {
            return;
        }

        try
        {
            await TransactionService.DeleteAsync(t.Id);
            Toasts.ShowSuccess("Transaction supprimee", label);
            await LoadAllAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Echec de la suppression de la transaction {Id}", t.Id);
            Toasts.ShowError("Erreur", "La suppression a echoue.");
        }
    }
}
