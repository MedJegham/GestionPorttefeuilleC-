{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=portfolio.db"
  },
  "Alerts": {
    "LossPercentOfInitial": 10,
    "LowLiquidityPercentOfInitial": 5,
    "HighVolatilityPercent": 35
  },
  "PriceData": {
    "Mode": "Simulated",
    "CacheMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
