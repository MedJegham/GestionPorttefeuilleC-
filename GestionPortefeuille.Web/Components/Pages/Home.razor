@page "/"
@rendermode InteractiveServer
@inject IPortfolioService PortfolioService
@inject IAnalyticsService AnalyticsService
@inject IPortfolioAlertService AlertService
@inject ToastService Toasts
@inject ILogger<Home> Logger

<PageTitle>Dashboard</PageTitle>

<div class="page-header">
    <i class="bi bi-speedometer2"></i>
    <h1>Tableau de bord</h1>
    @if (snapshot is not null)
    {
        <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="ReloadAsync" title="Actualiser">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    }
</div>

@if (loadError)
{
    <div class="alert alert-danger d-flex justify-content-between align-items-center">
        <span><i class="bi bi-exclamation-triangle me-2"></i>Impossible de charger le tableau de bord.</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadAsync">
            <i class="bi bi-arrow-clockwise me-1"></i>Reessayer
        </button>
    </div>
}
else if (snapshot is null)
{
    <div class="row g-3 mb-3" aria-busy="true" aria-label="Chargement du tableau de bord">
        <div class="col-lg-5 col-md-6">
            <div class="skeleton skeleton-kpi" style="height: 8.5rem;"></div>
        </div>
        <div class="col-lg-7 col-md-6">
            <div class="row g-3">
                <div class="col-md-4"><div class="skeleton skeleton-kpi"></div></div>
                <div class="col-md-4"><div class="skeleton skeleton-kpi"></div></div>
                <div class="col-md-4"><div class="skeleton skeleton-kpi"></div></div>
            </div>
        </div>
    </div>
    <div class="card p-3 mb-3">
        <div class="skeleton skeleton-line w-40"></div>
        <div class="skeleton" style="height: 220px; margin-top: 0.75rem;"></div>
    </div>
    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card p-3">
                <div class="skeleton skeleton-line w-60"></div>
                <div class="skeleton skeleton-line w-80"></div>
                <div class="skeleton skeleton-line w-40"></div>
                <div class="skeleton skeleton-line w-60"></div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card p-3">
                <div class="skeleton skeleton-line w-60"></div>
                <div class="skeleton skeleton-line w-80"></div>
                <div class="skeleton skeleton-line w-40"></div>
            </div>
        </div>
    </div>
}
else
{
    @if (alerts.Count > 0)
    {
        <div class="mb-3">
            @foreach (var alert in alerts)
            {
                <div class="alert @(AlertCss(alert.Severity)) mb-2 d-flex align-items-start gap-2" role="alert">
                    <i class="bi @AlertIcon(alert.Severity) mt-1"></i>
                    <div>
                        <strong>@alert.Title</strong> — @alert.Message
                    </div>
                </div>
            }
        </div>
    }

    <div class="row g-3 mb-3">
        <div class="col-lg-5 col-md-6">
            <div class="card kpi-card kpi-accent kpi-feature h-100">
                <div class="kpi-label"><i class="bi bi-cash-stack"></i>Valeur totale</div>
                <div class="kpi-value">@snapshot.TotalValue.ToString("C")</div>
                <div class="kpi-trend">@snapshot.Holdings.Count actif(s) &middot; portefeuille consolide</div>
            </div>
        </div>
        <div class="col-lg-7 col-md-6">
            <div class="row g-3 h-100">
                <div class="col-md-4">
                    <div class="card kpi-card h-100">
                        <div class="kpi-label"><i class="bi bi-wallet2"></i>Liquidite</div>
                        <div class="kpi-value">@snapshot.AvailableCash.ToString("C")</div>
                        <div class="kpi-trend">Disponible</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card kpi-card @(snapshot.GainLoss >= 0 ? "kpi-success" : "kpi-danger") h-100">
                        <div class="kpi-label">
                            <i class="bi @(snapshot.GainLoss >= 0 ? "bi-graph-up-arrow" : "bi-graph-down-arrow")"></i>
                            Gain / Perte
                        </div>
                        <div class="kpi-value @(snapshot.GainLoss >= 0 ? "text-success" : "text-danger")">@snapshot.GainLoss.ToString("C")</div>
                        <span class="kpi-trend-badge @(snapshot.GainLoss >= 0 ? "up" : "down")">
                            <i class="bi @(snapshot.GainLoss >= 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i>
                            Plus-values latentes
                        </span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card kpi-card @(snapshot.RoiPercent >= 0 ? "kpi-success" : "kpi-danger") h-100">
                        <div class="kpi-label"><i class="bi bi-percent"></i>ROI</div>
                        <div class="kpi-value @(snapshot.RoiPercent >= 0 ? "text-success" : "text-danger")">@snapshot.RoiPercent.ToString("N2")%</div>
                        <span class="kpi-trend-badge @(snapshot.RoiPercent >= 0 ? "up" : "down")">
                            <i class="bi @(snapshot.RoiPercent >= 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i>
                            Rendement global
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card p-3 mb-3">
        <h5 class="d-flex align-items-center gap-2"><i class="bi bi-bar-chart-line text-muted"></i>Graphiques</h5>
        <DashboardCharts PieLabels="pieLabels"
                         PieValues="pieValues"
                         LineLabels="lineLabels"
                         LineValues="lineValues" />
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0 d-flex align-items-center gap-2"><i class="bi bi-pie-chart text-muted"></i>Repartition du portefeuille</h5>
                    <span class="text-muted small">@snapshot.Holdings.Count actif(s)</span>
                </div>
                @if (snapshot.Holdings.Count == 0)
                {
                    <div class="empty-state">
                        <i class="bi bi-pie-chart empty-icon"></i>
                        <div class="empty-title">Aucune position ouverte</div>
                        <p class="empty-message">Ajoutez votre premier actif pour visualiser la repartition de votre portefeuille.</p>
                        <a class="btn btn-primary btn-sm d-inline-flex align-items-center gap-2" href="/assets">
                            <i class="bi bi-plus-lg"></i>Ajouter un actif
                        </a>
                    </div>
                }
                else
                {
                    <div class="section-label"><i class="bi bi-bookmark"></i>Par actif</div>
                    @foreach (var h in snapshot.Holdings)
                    {
                        <div class="mb-2">
                            <div class="d-flex justify-content-between small">
                                <span class="fw-semibold">@h.Symbol</span>
                                <span class="text-muted">@h.AllocationPercent.ToString("N1")%</span>
                            </div>
                            <div class="progress" role="progressbar">
                                <div class="progress-bar" style="width:@($"{Math.Max(2, h.AllocationPercent):N2}%")"></div>
                            </div>
                        </div>
                    }

                    <div class="section-label mt-3"><i class="bi bi-diagram-3"></i>Par type d'actif</div>
                    @foreach (var kv in snapshot.AllocationByType)
                    {
                        <div class="mb-2">
                            <div class="d-flex justify-content-between small">
                                <span class="fw-semibold">@kv.Key</span>
                                <span class="text-muted">@kv.Value.ToString("N1")%</span>
                            </div>
                            <div class="progress" role="progressbar">
                                <div class="progress-bar bg-info" style="width:@($"{Math.Max(2, kv.Value):N2}%")"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0 d-flex align-items-center gap-2"><i class="bi bi-cpu text-muted"></i>Analyse Data Science</h5>
                    <button class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1" @onclick="ReloadAsync">
                        <i class="bi bi-arrow-clockwise"></i>Actualiser
                    </button>
                </div>
                @if (analytics.Count == 0)
                {
                    <div class="empty-state">
                        <i class="bi bi-bar-chart-line empty-icon"></i>
                        <div class="empty-title">Pas encore de donnees analytiques</div>
                        <p class="empty-message">Les indicateurs apparaitront apres l'enregistrement de cours historiques.</p>
                    </div>
                }
                else
                {
                    @foreach (var item in analytics)
                    {
                        <div class="signal-card">
                            <div class="signal-badge @SignalBadgeClass(item.Signal)" title="@item.Signal">
                                <i class="bi @SignalIcon(item.Signal)"></i>
                            </div>
                            <div class="signal-body">
                                <div>
                                    <span class="signal-symbol">@item.Symbol</span>
                                    <span class="tag-signal @SignalClass(item.Signal)">@item.Signal</span>
                                </div>
                                <div class="signal-meta">
                                    Volatilite <span class="tabular-nums fw-semibold">@item.VolatilityPercent.ToString("N2")%</span>
                                    &middot;
                                    Max DD <span class="tabular-nums fw-semibold">@item.MaxDrawdownPercent.ToString("N2")%</span>
                                </div>
                                <div class="signal-meta @(item.DistanceToSmaPercent >= 0 ? "text-success" : "text-danger")">
                                    <i class="bi @(item.DistanceToSmaPercent >= 0 ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i>
                                    Ecart SMA(20) : <span class="tabular-nums fw-semibold">@item.DistanceToSmaPercent.ToString("N2")%</span>
                                </div>
                            </div>
                            <div class="signal-stats">
                                <div class="signal-sharpe">@item.SharpeLikeAnnualized.ToString("N2")</div>
                                <div class="signal-substat">Sharpe ann.</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="card p-3">
                <h5 class="d-flex align-items-center gap-2 mb-3"><i class="bi bi-table text-muted"></i>Performance par actif (CMP / cout moyen pondere)</h5>
                @if (snapshot.Holdings.Count == 0)
                {
                    <div class="empty-state py-3">
                        <i class="bi bi-table empty-icon"></i>
                        <p class="empty-message mb-0">Aucune position pour calculer la performance.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Symbole</th>
                                    <th class="text-end">Quantite</th>
                                    <th class="text-end">CMP</th>
                                    <th class="text-end">Cout de revient</th>
                                    <th class="text-end">Cours</th>
                                    <th class="text-end">Valorisation</th>
                                    <th class="text-end">Gain / Perte</th>
                                    <th class="text-end">Poids</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in snapshot.Holdings)
                                {
                                    <tr>
                                        <td><strong>@h.Symbol</strong> <span class="text-muted small">@h.Name</span></td>
                                        <td class="text-end">@h.Quantity.ToString("N4")</td>
                                        <td class="text-end">@h.AverageBuyPrice.ToString("C")</td>
                                        <td class="text-end">@h.CostBasis.ToString("C")</td>
                                        <td class="text-end">@h.CurrentPrice.ToString("C")</td>
                                        <td class="text-end">@h.MarketValue.ToString("C")</td>
                                        <td class="text-end @(h.GainLoss >= 0 ? "text-success" : "text-danger")">@h.GainLoss.ToString("C")</td>
                                        <td class="text-end">@h.AllocationPercent.ToString("N1")%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private PortfolioSnapshot? snapshot;
    private List<AssetAnalytics> analytics = [];
    private List<PortfolioAlert> alerts = [];
    private List<string> pieLabels = [];
    private List<decimal> pieValues = [];
    private List<string> lineLabels = [];
    private List<decimal> lineValues = [];
    private bool loadError;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        loadError = false;
        try
        {
            await AnalyticsService.EnsurePriceHistorySeedAsync();
            snapshot = await PortfolioService.GetSnapshotAsync();
            if (snapshot is not null)
            {
                await PortfolioService.RecordDailyPortfolioValueAsync(snapshot.TotalValue);
            }

            analytics = await AnalyticsService.GetAssetAnalyticsAsync();
            alerts = (await AlertService.GetAlertsAsync()).ToList();

            pieLabels = snapshot?.Holdings.Select(h => h.Symbol).ToList() ?? [];
            pieValues = snapshot?.Holdings.Select(h => h.MarketValue).ToList() ?? [];

            var hist = await PortfolioService.GetPortfolioValueHistoryAsync(180);
            lineLabels = hist.Select(p => p.Date.ToString("yyyy-MM-dd")).ToList();
            lineValues = hist.Select(p => p.TotalValue).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Echec du chargement du dashboard");
            loadError = true;
            Toasts.ShowError("Erreur de chargement", "Impossible de recuperer les donnees du portefeuille.");
        }
    }

    private static string SignalClass(TrendSignal signal) => signal switch
    {
        TrendSignal.Bullish => "bg-success-subtle text-success",
        TrendSignal.Bearish => "bg-danger-subtle text-danger",
        _ => "bg-secondary-subtle text-secondary"
    };

    private static string SignalBadgeClass(TrendSignal signal) => signal switch
    {
        TrendSignal.Bullish => "bullish",
        TrendSignal.Bearish => "bearish",
        _ => "neutral"
    };

    private static string SignalIcon(TrendSignal signal) => signal switch
    {
        TrendSignal.Bullish => "bi-arrow-up-right",
        TrendSignal.Bearish => "bi-arrow-down-right",
        _ => "bi-dash"
    };

    private static string AlertCss(AlertSeverity s) => s switch
    {
        AlertSeverity.Danger => "alert-danger",
        AlertSeverity.Warning => "alert-warning",
        _ => "alert-info"
    };

    private static string AlertIcon(AlertSeverity s) => s switch
    {
        AlertSeverity.Danger => "bi-exclamation-octagon",
        AlertSeverity.Warning => "bi-exclamation-triangle",
        _ => "bi-info-circle"
    };
}
