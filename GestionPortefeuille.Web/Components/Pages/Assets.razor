@page "/assets"
@rendermode InteractiveServer
@inject IAssetService AssetService
@inject ToastService Toasts
@inject ILogger<Assets> Logger

<PageTitle>Actifs</PageTitle>

<div class="page-header">
    <i class="bi bi-coin"></i>
    <h1>Gestion des actifs</h1>
</div>

<ConfirmDialog @ref="confirmDialog" Title="Supprimer l'actif" />

@if (loadError)
{
    <div class="alert alert-danger d-flex justify-content-between align-items-center">
        <span>Echec du chargement des actifs.</span>
        <button class="btn btn-sm btn-outline-light" @onclick="() => LoadPageAsync(page)">Reessayer</button>
    </div>
}

<div class="card p-3 mb-3">
    <div class="section-label"><i class="bi bi-funnel"></i>Filtres et recherche</div>
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label">Recherche</label>
            <div class="position-relative">
                <i class="bi bi-search position-absolute" style="left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--gp-text-subtle); font-size: 0.85rem;"></i>
                <input class="form-control" style="padding-left: 2.1rem;" value="@searchDraft" @oninput="OnSearchInput" placeholder="Symbole, nom..." />
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label">Type</label>
            <select class="form-select" @bind="typeFilter" @bind:after="OnFilterChanged">
                <option value="">Tous</option>
                <option value="Stock">Stock</option>
                <option value="Crypto">Crypto</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Tri</label>
            <select class="form-select" @bind="sortBy" @bind:after="OnFilterChanged">
                <option value="symbol">Symbole</option>
                <option value="name">Nom</option>
                <option value="type">Type</option>
                <option value="price">Prix</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label d-block">Ordre</label>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="sortDesc" @bind:after="OnFilterChanged" id="sortDesc" />
                <label class="form-check-label" for="sortDesc">Decroissant</label>
            </div>
        </div>
    </div>
    <div class="row g-2 mt-2 align-items-end">
        <div class="col-md-2">
            <button class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-1" @onclick="() => LoadPageAsync(1)">
                <i class="bi bi-check2"></i>Appliquer
            </button>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-1" @onclick="ResetForm">
                <i class="bi bi-plus-lg"></i>Nouveau
            </button>
        </div>
    </div>
</div>

<div class="card p-3 mb-3">
    <div class="section-label"><i class="bi bi-pencil-square"></i>@(assetForm.Id == 0 ? "Ajouter un actif" : $"Modifier {assetForm.Symbol}")</div>
    <EditForm Model="assetForm" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label">Symbole</label>
                <InputText class="form-control" @bind-Value="assetForm.Symbol" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Nom</label>
                <InputText class="form-control" @bind-Value="assetForm.Name" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Type</label>
                <InputSelect class="form-select" @bind-Value="assetForm.AssetType">
                    @foreach (var type in Enum.GetValues<AssetType>())
                    {
                        <option value="@type">@type</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-2">
                <label class="form-label">Prix actuel</label>
                <InputNumber class="form-control" @bind-Value="assetForm.CurrentPrice" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-1" type="submit">
                    <i class="bi @(assetForm.Id == 0 ? "bi-plus-lg" : "bi-check2")"></i>
                    @((assetForm.Id == 0) ? "Ajouter" : "Mettre a jour")
                </button>
            </div>
        </div>
    </EditForm>
</div>

<div class="card p-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
        <span class="text-muted small"><i class="bi bi-list-ul me-1"></i>@totalCount actif(s) &middot; @($"Page {page} / {totalPages}")</span>
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary" disabled="@(page <= 1)" @onclick="() => LoadPageAsync(page - 1)" title="Page precedente">
                <i class="bi bi-chevron-left"></i>
            </button>
            <button class="btn btn-outline-secondary" disabled="@(page >= totalPages)" @onclick="() => LoadPageAsync(page + 1)" title="Page suivante">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
    @if (isLoading)
    {
        <LoadingSpinner Message="Chargement des actifs..." />
    }
    else if (pageItems.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-collection empty-icon"></i>
            <div class="empty-title">Aucun actif trouve</div>
            <p class="empty-message">Renseignez le formulaire ci-dessus pour creer votre premier actif (action ou crypto).</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Symbole</th>
                        <th>Nom</th>
                        <th>Type</th>
                        <th class="text-end">Prix</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in pageItems)
                    {
                        <tr>
                            <td><strong>@asset.Symbol</strong></td>
                            <td class="text-muted">@asset.Name</td>
                            <td>
                                <span class="tag-signal @(asset.AssetType == AssetType.Crypto ? "bg-warning-subtle text-warning" : "bg-secondary-subtle")">
                                    <i class="bi @(asset.AssetType == AssetType.Crypto ? "bi-currency-bitcoin" : "bi-building")"></i>
                                    @asset.AssetType
                                </span>
                            </td>
                            <td class="text-end tabular-nums fw-semibold">@asset.CurrentPrice.ToString("C")</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Edit(asset)" title="Editer">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(asset)" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private const int PageSize = 8;

    private string? search;
    private string? searchDraft;
    private string? typeFilter;
    private string sortBy = "symbol";
    private bool sortDesc;
    private int page = 1;
    private int totalCount;
    private int totalPages => Math.Max(1, (int)Math.Ceiling(totalCount / (double)PageSize));
    private List<Asset> pageItems = [];
    private Asset assetForm = new() { AssetType = AssetType.Stock, CurrentPrice = 100m };
    private CancellationTokenSource? _searchDebounceCts;
    private ConfirmDialog? confirmDialog;
    private bool isLoading;
    private bool loadError;

    protected override async Task OnInitializedAsync()
    {
        searchDraft = search;
        await LoadPageAsync(1);
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchDraft = e.Value?.ToString();
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _searchDebounceCts = new CancellationTokenSource();
        var token = _searchDebounceCts.Token;
        try
        {
            await Task.Delay(400, token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        search = searchDraft;
        await InvokeAsync(async () =>
        {
            await LoadPageAsync(1);
            StateHasChanged();
        });
    }

    private async Task OnFilterChanged()
    {
        await LoadPageAsync(1);
    }

    private async Task LoadPageAsync(int newPage)
    {
        page = Math.Max(1, newPage);
        isLoading = true;
        loadError = false;
        try
        {
            var result = await AssetService.GetPagedAsync(search, typeFilter, page, PageSize, sortBy, sortDesc);
            pageItems = result.Items;
            totalCount = result.TotalCount;
            if (page > totalPages && totalPages > 0)
            {
                page = totalPages;
                result = await AssetService.GetPagedAsync(search, typeFilter, page, PageSize, sortBy, sortDesc);
                pageItems = result.Items;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Echec du chargement des actifs (page {Page})", page);
            loadError = true;
            Toasts.ShowError("Erreur", "Impossible de charger la liste des actifs.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void Edit(Asset asset)
    {
        assetForm = new Asset
        {
            Id = asset.Id,
            Symbol = asset.Symbol,
            Name = asset.Name,
            AssetType = asset.AssetType,
            CurrentPrice = asset.CurrentPrice
        };
    }

    private async Task SaveAsync()
    {
        try
        {
            if (assetForm.Id == 0)
            {
                await AssetService.CreateAsync(assetForm);
                Toasts.ShowSuccess("Actif ajoute", assetForm.Symbol);
            }
            else
            {
                await AssetService.UpdateAsync(assetForm);
                Toasts.ShowSuccess("Actif mis a jour", assetForm.Symbol);
            }

            ResetForm();
            await LoadPageAsync(page);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Echec de l'enregistrement de l'actif {Symbol}", assetForm.Symbol);
            Toasts.ShowError("Erreur", "L'enregistrement a echoue.");
        }
    }

    private async Task DeleteAsync(Asset asset)
    {
        if (confirmDialog is null)
        {
            return;
        }

        var confirmed = await confirmDialog.ShowAsync(
            $"Voulez-vous vraiment supprimer l'actif {asset.Symbol} ? Cette action est irreversible.");

        if (!confirmed)
        {
            return;
        }

        try
        {
            await AssetService.DeleteAsync(asset.Id);
            Toasts.ShowSuccess("Actif supprime", asset.Symbol);
            await LoadPageAsync(page);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Echec de la suppression de l'actif {AssetId}", asset.Id);
            Toasts.ShowError("Erreur", "La suppression a echoue (l'actif a peut-etre des transactions liees).");
        }
    }

    private void ResetForm()
    {
        assetForm = new Asset { AssetType = AssetType.Stock, CurrentPrice = 100m };
    }
}
