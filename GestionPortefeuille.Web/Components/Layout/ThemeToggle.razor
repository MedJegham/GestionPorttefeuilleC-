@rendermode InteractiveServer
@inject IJSRuntime Js

<button type="button" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-2" @onclick="ToggleAsync" title="Basculer le theme">
    <i class="bi @IconClass"></i>
    <span class="d-none d-md-inline">@ButtonLabel</span>
</button>

@code {
    private string ButtonLabel { get; set; } = "Theme";
    private string IconClass { get; set; } = "bi-moon-stars";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SyncLabelAsync();
            StateHasChanged();
        }
    }

    private async Task ToggleAsync()
    {
        var next = await Js.InvokeAsync<string>("themeInterop.toggle");
        ApplyState(next);
    }

    private async Task SyncLabelAsync()
    {
        var cur = await Js.InvokeAsync<string>("themeInterop.current");
        ApplyState(cur);
    }

    private void ApplyState(string current)
    {
        if (current == "dark")
        {
            ButtonLabel = "Mode clair";
            IconClass = "bi-sun";
        }
        else
        {
            ButtonLabel = "Mode sombre";
            IconClass = "bi-moon-stars";
        }
    }
}
